{
  "name": "statemotion-panel",
  "version": "0.1.0",
  "private": true,
  "description": "StateMotion Preset Panel (UXP) for Premiere Pro. Independent clean-room implementation.",
  "type": "module",
  "scripts": {
    "build": "node tools/build-panel.mjs",
    "typecheck": "tsc --noEmit",
    "test": "node tools/run-panel-tests.mjs",
    "gen:contract": "node tools/generate-contract.js",
    "gen:presets": "node --experimental-transform-types tools/generate-bundled-presets.ts"
  },
  "devDependencies": {
    "@adobe/premierepro": "26.3.0",
    "esbuild": "0.24.2",
    "typescript": "5.9.3"
  }
}
