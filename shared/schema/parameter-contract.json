        { "name": "Linear", "value": 0 },
        { "name": "EaseIn", "value": 1 },
        { "name": "EaseOut", "value": 2 },
        { "name": "EaseInOut", "value": 3 },
        { "name": "Custom", "value": 4 }
      ]
    }
