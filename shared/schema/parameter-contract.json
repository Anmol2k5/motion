      "description": "Approved first-slice progress modes. Append-only; never reorder/reuse.",
      "values": [
        { "name": "AToB", "value": 0 },
        { "name": "BToA", "value": 1 },
        { "name": "AToBToA", "value": 2 },
        { "name": "BToAToB", "value": 3 },
        { "name": "HoldA", "value": 4 },
        { "name": "HoldB", "value": 5 },
        { "name": "Manual", "value": 6 }
      ]
    },
    "AlignmentMode": {
      "description": "Approved first-slice alignment modes. Append-only; never reorder/reuse.",
      "values": [
        { "name": "ClipStart", "value": 0 },
        { "name": "ClipEnd", "value": 1 },
        { "name": "EntireClip", "value": 2 }
      ]
    },
    "EasingMode": {
      "description": "Easing curve selector for A/B interpolation. Append-only; never reorder/reuse. Numeric identity is the persistence contract (not popup label).",
